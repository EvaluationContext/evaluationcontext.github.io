			        "40%",          // width
			        8,              // height
			        blank(),        // rx
			        blank(),        // ry
			        DaxLib.SVG.Attr.Shapes(
			            DaxLib.SVG.Color.Theme(
			                MAX( Theme[Theme] ),
			                MIN( Variant[Variant] )
