			        DaxLib.SVG.Color.Theme(
			            MAX( Theme[Theme] ),
			            MIN( Variant[Variant] ) + 1
			        ),                  // pointColor
			        0.5                 // jitterAmount
			    )
			VAR Heatmap = 
			    DaxLib.SVG.Compound.Heatmap(
			        0,                  // x
			        0,                  // y
			        100,                // width
			        20,                 // height
			        0.05,               // paddingX
			        0.02,               // paddingY
			        Dates[Date],        // axisRef
			        [Total Cost],       // measureRef
			        MAX( Samples[Samples] ), // samples
			        MAX( Bandwidth[Bandwidth] ), // bandwidth
			        DaxLib.SVG.Color.Theme(
			            MAX( Theme[Theme] ),
			            MIN( Variant[Variant] )
			        )                   // color
			    )
			VAR Combined = 
			    Heatmap &
			    Jitter
			RETURN
			
			    IF(
			        NOT ISBLANK( Combined ),
			        DaxLib.SVG.SVG(
			            100,
			            20,
			            BLANK(),
			            Combined,                 
			            BLANK()
			        )
			    )
