	measure Hard = ```
			
			"data:image/svg+xml;utf8, <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 3000 3000' width='1000' height='1000'>
			  <defs>
			    <filter id='cpu-melter' x='-20%' y='-20%' width='140%' height='140%'>
			      
			      <feTurbulence type='fractalNoise' baseFrequency='0.05' numOctaves='20' result='noise' />
			      
			      <feDisplacementMap in='noise' in2='noise' scale='300' xChannelSelector='R' yChannelSelector='G' result='displaced' />
			      
			      <feGaussianBlur in='displaced' stdDeviation='50' result='blurred' />
			      
			      <feSpecularLighting in='blurred' surfaceScale='20' specularConstant='2.5' specularExponent='40' lighting-color='#00ffcc' result='lit'>
			        <fePointLight x='1500' y='1500' z='300' />
			      </feSpecularLighting>
			      
			      <feBlend mode='color-dodge' in='lit' in2='SourceGraphic' />
			    </filter>
			  </defs>
			
			  <rect width='3000' height='3000' fill='#ff0055' filter='url(#cpu-melter)' />
			</svg>"
