	measure 'Clip Path' = ```
			
			VAR _Defs = 
			    DaxLib.SVG.Element.Defs(
			        DaxLib.SVG.Def.ClipPath(
			            "clip-circle",      // id
			            DaxLib.SVG.Element.Circle(
			                "50%",          // cx 
			                "80%",          // cy
			                8,              // r
			                BLANK(),        // attributes
			                BLANK()         // transforms
			            )                   // elements
			        )
			    )
			
			VAR _Rectangle = 
			    DaxLib.SVG.Element.Rect(
			        "0%",           // x
			        "0%",           // y
			        "100%",         // width
			        "80%",          // height
			        BLANK(),        // rx
			        BLANK(),        // ry
			        DaxLib.SVG.Attr.Shapes(
			            DaxLib.SVG.Color.Theme(
			                MAX( Theme[Theme] ),
			                MIN( Variant[Variant] )
			            ),          // fill
			            BLANK(),    // fillOpacity
			            BLANK(),    // fillRule   
			            BLANK(),    // stroke
			            BLANK(),    // strokeWidth
			            BLANK(),    // strokeOpacity
			            BLANK()     // opacity
			        ) &
			        "clip-path='url(#clip-circle)'",  // Add clip-path reference
			        BLANK()         // transforms
			    )
			
			RETURN
			DaxLib.SVG.SVG(
			    100,                // width
			    20,                 // height
			    BLANK(),            // viewbox
			    _Defs &             // definitions including clipPath
			    _Rectangle,         // clipped rectangle
			    BLANK()             // sortValue
			)
			```
		displayFolder: SVG\Defs
		lineageTag: 0ee21ac1-95fc-44e3-89d5-6a67c09cd0ed
		dataCategory: ImageUrl

	measure 'Compound.Line' = ```
			
			VAR Compound = 
			    DaxLib.SVG.Compound.Line(
			        SELECTEDVALUE( x[x], 0 ), // x
			        SELECTEDVALUE( y[y], 0 ), // y
			        SELECTEDVALUE( Width[Width], 100 ), // width
			        SELECTEDVALUE( Height[Height], 20), // height
			        0.05,               // paddingX
			        0.1,               // paddingY
			        Dates[Date],        // axisRef
			        [Total Cost],       // measureRef
			        DaxLib.SVG.Color.Theme(
			            MAX( Theme[Theme] ),
			            MIN( Variant[Variant] )
			        ),                  // lineColor
			        DaxLib.SVG.Color.PerformanceTheme(
			           "Stoplight",
			            "veryBad"
			        ),                  // minMarkColor
			        DaxLib.SVG.Color.PerformanceTheme(
			           "Stoplight",
			            "veryGood"
			        ),                  // maxMarkColor
			        [Axes Toggle],      // showAxis
			        8                  // axisFontSize
			    )
			RETURN
			
			    IF(
			        NOT ISBLANK( Compound ),
			        DaxLib.SVG.SVG(
			            SELECTEDVALUE( Width[Width], 100 ), // width
			            SELECTEDVALUE( Height[Height], 20), // height
			            BLANK(),
			            Compound,
			            BLANK()
			        )
			    )
			```
