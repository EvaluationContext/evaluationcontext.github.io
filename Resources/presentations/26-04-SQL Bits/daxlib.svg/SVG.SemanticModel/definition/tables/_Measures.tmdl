table _Measures
	lineageTag: fc71a644-ec86-4b02-8cbe-a3b62e5b9769

	measure 'Compound.Pill' = ```
			
			VAR Compound = 
			    DaxLib.SVG.Compound.Pill(
			        SELECTEDVALUE( x[x], 0 ), // x
			        SELECTEDVALUE( y[y], 0 ), // y
			        SELECTEDVALUE( Width[Width], 100 ), // width
			        SELECTEDVALUE( Height[Height], 20), // height
			        0.05,               // paddingX
			        0.02,               // paddingY
			        MAX( Products[Brand] ), // txt
			        DaxLib.SVG.Color.Theme(
			            MAX( Theme[Theme] ),
			            MIN( Variant[Variant] )
			        )                  // color
			    )
			RETURN
			
			    IF( 
			        NOT ISBLANK( Compound ) && NOT ISBLANK( [Total Cost] ),
			        DaxLib.SVG.SVG(
			            SELECTEDVALUE( Width[Width], 100 ), // width
			            SELECTEDVALUE( Height[Height], 20), // height
			            BLANK(),
			            Compound,
			            BLANK()
			        )
			    )
			```
		displayFolder: SVG\Compound
		lineageTag: 9c01df68-7f3e-486f-ba39-70e260a26808
		dataCategory: ImageUrl

