	measure 'Many Circles' = ```
			
			VAR NumItems = 1000
			VAR Circles = 
			ADDCOLUMNS(
			    GENERATESERIES(1, NumItems),
			    "cx", RAND() * 200,
			    "cy", RAND() * 200,
			    "r", RAND() * 5 + 1,
			    "fill", "hsl(" & RAND() * 360 & ", 80%, 50%)"
			    )
			VAR SvgItems = 
			CONCATENATEX(
			    Circles,
			    "<circle cx='" & [cx] & "' cy='" & [cy] & "' r='" & [r] & "' fill='" & [fill] & "' />",
			    UNICHAR(10)
			)
			RETURN
			"data:image/svg+xml;utf8,
			<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'>" & UNICHAR(10) &
			SvgItems & UNICHAR(10) &
			"</svg>"
			```
		lineageTag: 1d362b57-4687-46db-9395-400999e63f7e
		dataCategory: ImageUrl

