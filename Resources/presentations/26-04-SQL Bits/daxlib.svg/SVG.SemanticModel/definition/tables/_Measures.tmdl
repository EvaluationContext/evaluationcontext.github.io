			            BLANK(),    // fillRule
			             DaxLib.SVG.Color.Theme(
			                MAX( Theme[Theme] ),
			                MIN( Variant[Variant] )
			            ),          // stroke
			            2,          // strokeWidth
			            0.9,        // strokeOpacity
			            BLANK()     // opacity
			        ),              // attributes
			        DaxLib.SVG.Transforms(
			            -15,        // translate
			            5,          // rotate
			            BLANK(),    // scale
			            -20,        // skewX
			            BLANK()     // skewY
			        )               // transforms
			    ),                  // contents
			    BLANK()             // sortValue
			)
