	measure 'Violin SVG' = ```
			
			VAR _SvgWidth = 150
			VAR _SvgHeight = 20
			
			VAR _samples = 50
			VAR _bandwidth = 60 // Kernal width, adjust to avoid over or under fitting
			
			VAR _range = 
			    MAXX(
			        ALLSELECTED( Dates[YearMonth] )
			        ,[Total Cost]
			    )
			
			VAR _rangePerSample = _range / _samples
			VAR _values =
			    ADDCOLUMNS(
			        ALLSELECTED( Dates[YearMonth] )
			        ,"@Val", [Total Cost]
			    )
			VAR _numValues = COUNTAX( _values, [@Val] )
			VAR _KDE = // Kernal Density Estimation
			    ADDCOLUMNS(
			        GENERATESERIES( 0, _samples + 1, 1 )
			        ,"@inputX", _rangePerSample * [Value]
			        ,"@KDE", ( 1 / _numValues ) * SUMX( _values, NORM.DIST( _rangePerSample * [Value], [@val], _bandwidth, false ) ) // Normal distribution for Kernal (Gaussian, Uniform, Triangular etc.)
			    )
			VAR _maxKDE = MAXX( _KDE, [@KDE] )
			VAR _points =
			    ADDCOLUMNS(
			        _KDE
			        ,"@x",
			            VAR _xInputStart =           0                         // The lowest number of the range input
			            VAR _xInputEnd =             _range                    // The largest number of the range input
			            VAR _xOutputStart =          0                         // The lowest number of the range output
			            VAR _xOutputEnd =            _SvgWidth                 // The largest number of the range output         
			            VAR _xOutputVal =            _xOutputStart + ((_xOutputEnd - _xOutputStart) / (_xInputEnd - _xInputStart)) * ( [@inputX] - _xInputStart)
			            RETURN
			            _xOutputVal
			        ,"@y",
			            VAR _yInputStart =           0                         // The lowest number of the range input
			            VAR _yInputEnd =             _maxKDE                   // The largest number of the range input
			            VAR _yOutputStart =          _SvgHeight / 2            // The lowest number of the range output
			            VAR _yOutputEnd =            0                         // The largest number of the range output         
			            VAR _yOutputVal =            _yOutputStart + ((_yOutputEnd - _yOutputStart) / (_yInputEnd - _yInputStart)) * ([@KDE] - _yInputStart)
			            RETURN
			            _yOutputVal
			    )
			VAR _pointsAndPreviousPoint = 
			    NATURALLEFTOUTERJOIN(
			        _points
			        ,SELECTCOLUMNS(
			            _points
			            ,"Value", [Value] + 1
			            ,"@prevX", [@x]
			            ,"@prevY", [@y]
			        )
			    )
			VAR _plusControlPoint = // Calculate control point for cubic Bézier curve. Assumes they half way between points, at the same height as the current point
			    ADDCOLUMNS(
			        _pointsAndPreviousPoint
			        ,"@cx", [@prevX] + (([@x] - [@prevX]) / 2)
			        ,"@cy", [@y]
			    )
			VAR _topCurves =
			    CONCATENATEX(
			        _plusControlPoint
			        ,"S " & [@cx] & " " & [@cy] & ", " & [@x] & " " & [@y] // cubic Bézier curve
			        , " "
			        , [Value]
			)
			VAR _bottomCurves = // top curve inverted
			    CONCATENATEX(
			        _plusControlPoint
			        ,"S " & [@cx] & " " & (_SvgHeight / 2) - ([@cy] - (_SvgHeight / 2)) & ", " & [@x] & " " & (_SvgHeight / 2) - ([@y] - (_SvgHeight / 2))
			        , " "
			        , [Value]
			)
			VAR _svg =
			    "data:image/svg+xml;utf8, <svg width=""" & _SvgWidth & """ height=""" & _SvgHeight &""" xmlns='http://www.w3.org/2000/svg'>" &
			    "<path d=' M 0 " & (_SvgHeight / 2) & " " & _topCurves & "M " & _SvgWidth & " " & (_SvgHeight / 2) & "' stroke='gray' fill='gray' fill-opacity='50%'/>" &
			    "<path d=' M 0 " & (_SvgHeight / 2) & " " & _bottomCurves & "M " & _SvgWidth & " " & (_SvgHeight / 2) & "' stroke='gray' fill='gray' fill-opacity='50%'/>" &
			    "</svg>"
			RETURN
			IF( not ISBLANK( _maxKDE ), _svg )
			```
		displayFolder: Demo
		lineageTag: f787ec50-7c63-4824-a94b-ade6b28eedec
		dataCategory: ImageUrl

	measure 'Slope Chart (Brand Aug-Sep 2025)' =
			
			VAR _m0 = "2025-08"
			VAR _m1 = "2025-09"
			
			VAR _w = 520
			VAR _h = 220
			VAR _padL = 120
			VAR _padR = 120
			VAR _padT = 24
			VAR _padB = 30
			
			VAR _x0 = _padL
			VAR _x1 = _w - _padR
			VAR _yTop = _padT
			VAR _yBot = _h - _padB
			
			VAR _brands =
			    FILTER (
			        ALLSELECTED ( Products[Brand] ),
			        NOT ISBLANK ( Products[Brand] )
			    )
			
			VAR _data =
			    ADDCOLUMNS (
			        _brands,
			        "@v0",
			            CALCULATE (
			                [Total Cost],
			                REMOVEFILTERS ( Dates[YearMonth] ),
			                TREATAS ( { _m0 }, Dates[YearMonth] )
			            ),
			        "@v1",
			            CALCULATE (
			                [Total Cost],
			                REMOVEFILTERS ( Dates[YearMonth] ),
			                TREATAS ( { _m1 }, Dates[YearMonth] )
			            )
			    )
			
			VAR _dataFiltered =
			    FILTER ( _data, NOT ( ISBLANK ( [@v0] ) && ISBLANK ( [@v1] ) ) )
			
			VAR _minV =
			    MINX ( _dataFiltered, IF ( [@v0] < [@v1], [@v0], [@v1] ) )
			VAR _maxV =
			    MAXX ( _dataFiltered, IF ( [@v0] > [@v1], [@v0], [@v1] ) )
			VAR _rng = MAX ( _maxV - _minV, 0.0000001 )
			
			VAR _lines =
			    CONCATENATEX (
			        _dataFiltered,
			        VAR _brand = Products[Brand]
			        VAR _v0 = [@v0]
			        VAR _v1 = [@v1]
			        VAR _y0 = _yBot - DIVIDE ( _v0 - _minV, _rng, 0 ) * ( _yBot - _yTop )
			        VAR _y1 = _yBot - DIVIDE ( _v1 - _minV, _rng, 0 ) * ( _yBot - _yTop )
			        VAR _stroke =
			            IF ( _v1 > _v0, "%232ca02c", IF ( _v1 < _v0, "%23d62728", "%237f7f7f" ) )
			        RETURN
			              "<line x1='" & FORMAT ( _x0, "0.##" ) & "' y1='" & FORMAT ( _y0, "0.##" ) &
			              "' x2='" & FORMAT ( _x1, "0.##" ) & "' y2='" & FORMAT ( _y1, "0.##" ) &
			              "' stroke='" & _stroke & "' stroke-width='2' opacity='0.9'/>"
			            & "<circle cx='" & FORMAT ( _x0, "0.##" ) & "' cy='" & FORMAT ( _y0, "0.##" ) &
			              "' r='2.8' fill='" & _stroke & "'/>"
			            & "<circle cx='" & FORMAT ( _x1, "0.##" ) & "' cy='" & FORMAT ( _y1, "0.##" ) &
			              "' r='2.8' fill='" & _stroke & "'/>"
			            & "<text x='" & FORMAT ( _x0 - 8, "0.##" ) & "' y='" & FORMAT ( _y0 + 3, "0.##" ) &
			              "' text-anchor='end' font-size='10' fill='%23555'>" & _brand & "</text>",
			        ""
			    )
			
			VAR _svg =
			    "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 " & _w & " " & _h & "'>"
			    & "<rect x='0' y='0' width='" & _w & "' height='" & _h & "' fill='white'/>"
			    & "<line x1='" & _x0 & "' y1='" & _yTop & "' x2='" & _x0 & "' y2='" & _yBot & "' stroke='%23bdbdbd'/>"
			    & "<line x1='" & _x1 & "' y1='" & _yTop & "' x2='" & _x1 & "' y2='" & _yBot & "' stroke='%23bdbdbd'/>"
			    & _lines
			    & "<text x='" & _x0 & "' y='" & (_h - 8) & "' text-anchor='middle' font-size='11' fill='%23666'>" & _m0 & "</text>"
			    & "<text x='" & _x1 & "' y='" & (_h - 8) & "' text-anchor='middle' font-size='11' fill='%23666'>" & _m1 & "</text>"
			    & "</svg>"
			
			RETURN
			    "data:image/svg+xml;utf8," & _svg
		lineageTag: 68ac4f99-f934-4a55-b507-ac043666d7e3

	measure daxlib =
			
			VAR _Aug =
			    CALCULATE (
			        [Total Cost],
			        REMOVEFILTERS ( Dates[YearMonth] ),
			        KEEPFILTERS ( Dates[YearMonth] = "2025-08" )
			    )
			VAR _Sep =
			    CALCULATE (
			        [Total Cost],
			        REMOVEFILTERS ( Dates[YearMonth] ),
			        KEEPFILTERS ( Dates[YearMonth] = "2025-09" )
			    )
			VAR _HasBoth = NOT ISBLANK ( _Aug ) && NOT ISBLANK ( _Sep )
			
			VAR _W = 140
			VAR _H = 44
			VAR _PadX = 10
			VAR _PadY = 6
			VAR _X1 = _PadX
			VAR _X2 = _W - _PadX
			
			VAR _MinV = MIN ( _Aug, _Sep )
			VAR _MaxV = MAX ( _Aug, _Sep )
			VAR _Range = _MaxV - _MinV
			VAR _PadV = IF ( _Range = 0, MAX ( ABS ( _MaxV ) * 0.05, 1 ), _Range * 0.20 )
			VAR _ScaleMin = _MinV - _PadV
			VAR _ScaleMax = _MaxV + _PadV
			
			VAR _Y1 =
			    IF (
			        _ScaleMax = _ScaleMin,
			        _H / 2,
			        DaxLib.SVG.Scale.Normalize ( _Aug, _ScaleMin, _ScaleMax, _H - _PadY, _PadY )
			    )
			VAR _Y2 =
			    IF (
			        _ScaleMax = _ScaleMin,
			        _H / 2,
			        DaxLib.SVG.Scale.Normalize ( _Sep, _ScaleMin, _ScaleMax, _H - _PadY, _PadY )
			    )
			
			VAR _Color =
			    SWITCH ( TRUE (), _Sep > _Aug, "#2E7D32", _Sep < _Aug, "#C62828", "#6B7280" )
			
			VAR _Line =
			    DaxLib.SVG.Element.Line (
			        _X1, _Y1, _X2, _Y2,
			        DaxLib.SVG.Attr.Shapes ( "none", BLANK (), BLANK (), _Color, 2, BLANK (), BLANK () ),
			        BLANK ()
			    )
			VAR _StartDot =
			    DaxLib.SVG.Element.Circle (
			        _X1, _Y1, 3,
			        DaxLib.SVG.Attr.Shapes ( "white", BLANK (), BLANK (), _Color, 2, BLANK (), BLANK () ),
			        BLANK ()
			    )
			VAR _EndDot =
			    DaxLib.SVG.Element.Circle (
			        _X2, _Y2, 3,
			        DaxLib.SVG.Attr.Shapes ( _Color, BLANK (), BLANK (), "white", 1, BLANK (), BLANK () ),
			        BLANK ()
			    )
			
			RETURN
			    IF (
			        _HasBoth,
			        DaxLib.SVG.SVG ( "100%", "100%", "0 0 " & _W & " " & _H, _Line & _StartDot & _EndDot, _Sep - _Aug )
			    )
		lineageTag: f14aa7c5-264b-4253-b3c2-97f39b8a4f83

